    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet combined = \"\";\nlet count = 1;\n\nitems.forEach((item) => {\n  const title = item.json.title || \"No title\";\n  const summary = item.json.summary || item.json.content || \"No summary available\";\n\n  combined += `${count}. ${title}\\n`;\n  combined += `${summary}\\n\\n`;\n  count++;\n});\n\nreturn [\n  {\n    json: {\n      news: combined\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
